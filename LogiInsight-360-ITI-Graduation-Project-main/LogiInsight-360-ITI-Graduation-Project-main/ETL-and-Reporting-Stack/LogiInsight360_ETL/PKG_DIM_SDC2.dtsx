                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT  c.Customer_ID,
        c.Customer_Name,
        c.Segment,
        c.Customer_Status,
        c.Credit_Limit,
        c.City_ID,
        ci.City_Name,
        r.Region_Name
FROM    Master.Customers c
LEFT JOIN Master.Cities  ci ON c.City_ID   = ci.City_ID
LEFT JOIN Master.Regions r  ON ci.Region_ID = r.Region_ID
WHERE   c.Is_Deleted = 0  -- مش بنجيب المحذوفين</property>
