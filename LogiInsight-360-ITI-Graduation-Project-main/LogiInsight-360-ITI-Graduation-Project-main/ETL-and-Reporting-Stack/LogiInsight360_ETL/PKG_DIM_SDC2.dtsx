                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT p.Product_ID, p.Product_SKU, p.Product_Name, p.Product_Category, p.Brand_Name, p.Storage_Type, p.Shelf_Life_Days, CASE WHEN p.Currency_Code = 'EGP' THEN p.Unit_Cost ELSE p.Unit_Cost * ISNULL(er.Exchange_Rate, 1) END AS Unit_Cost_EGP, CASE WHEN p.Currency_Code = 'EGP' THEN p.Unit_Price ELSE p.Unit_Price * ISNULL(er.Exchange_Rate, 1) END AS Unit_Price_EGP, p.Product_Type
FROM  Master.Products AS p LEFT OUTER JOIN
         Master.Exchange_Rates AS er ON er.From_Currency = p.Currency_Code AND er.To_Currency = 'EGP' AND er.Rate_Date = CAST(SYSDATETIME() AS DATE)
WHERE (p.Is_Deleted = 0)</property>
